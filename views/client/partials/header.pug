header.header 
  .container 
    .row.align-items-center
      .col-3
        .inner-logo 
          a(href = "/")
            img(src = "/images/logo.svg", alt ="Logo")
      .col-5 
        .box-search
          form(method = "GET" action = "/search/result")
            div(class ="form-group d-flex mb-0")
              input(
                type = "text"
                placeholder = "Nhập từ khóa..."
                class = "form-control"
                name = "keyword"
                value = keyword 
              ) 
              button(type = "submit" class ="btn btn-primary") Tìm
          .inner-suggest.show
            .inner-list
              //- a(href="/songs/detail/:slugSong" class="inner-item")
              //-   .inner-image
              //-     img(src="https://backend.daca.vn/assets/images/cat-doi-noi-sau.jpg")
              //-   .inner-info
              //-     .inner-title Cắt đôi nỗi sầu
              //-     .inner-singer
              //-       i(class="fa-solid fa-microphone-lines")
              //-       | Tăng Duy Tân
      .col-4 
        .inner-menu 
          ul  
            li 
              a(href = "/") <i class="fa-solid fa-house"></i> Trang chủ

            if(user)
              li 
                a(href = "/topics") <i class="fa-solid fa-music"></i> Chủ đề
              li 
                a(href = "/favorite-songs") <i class="fa-solid fa-heart"></i> Yêu thích
              li 
                a(href = "/user/logout") Đăng xuất
                
            else
              li 
                a(href = "/user/register") Đăng kí
              li 
                a(href = "/user/login") Đăng nhập