extends ../../layouts/default.pug
include ../../mixins/form-change-multi.pug
include ../../mixins/pagination.pug
include ../../mixins/search.pug
block main 
  h2(class ="mb-4") #{pageTitle}

  .card.mb-3 
    .card-header Quản lý bài hát
    .card-body 
      .row 
        .col-4
          +form-change-multi(`${prefixAdmin}/songs/change-multi?_method=PATCH`)
        .col-4 
          +search(keyword)
        .col-4.text-right 
          a(
            href = `${prefixAdmin}/songs/create`
            class = "btn btn-outline-success"
          ) + Thêm mới
        table(class = "table table-hover table-sm" checkbox-multi)
          thead
            tr 
              th 
                input(type = "checkbox" name = "checkall") 
              th STT
              th Hình ảnh 
              th Tiêu đề
              //- th Ca sĩ
              //- th Chủ đề
              //- th Vị trí
              th Trạng thái
              th Hành động
          tbody 
            each item, index in songs
              tr 
                td 
                  input(type = "checkbox" name = "id" value = item.id)
                td #{(pagination.currentPage-1)*(pagination.limitItem)+(index+1)}
                td 
                  img(src = item.avatar, alt = item.title width = "100px" height = "auto")
                td #{item.title}
                //- td Dữ liệu ca sĩ
                //- td Dữ liệu chủ đề
                //- td Dữ liệu vị trí
                td
                  if (item.status =="active")
                    a(
                      href = `javascript: ;` 
                      class = "badge badge-success" 
                      data-status = item.status 
                      data-id = item.id 
                      button-change-status
                      ) Hoạt động
                  else 
                    a(
                      href = `javascript: ;` 
                      class = "badge badge-danger" 
                      data-status = item.status 
                      data-id = item.id 
                      button-change-status
                      ) Dừng hoạt động
                td 
                  a(class = "btn btn-secondary btn-sm mr-1" href =`${prefixAdmin}/songs/detail/${item.id}`) Chi tiết
                  a(class = "btn btn-warning btn-sm mr-1" href =`${prefixAdmin}/songs/edit/${item.id}`) Sửa
                  button(class = "btn btn-danger btn-sm" button-delete data-id = item.id) Xóa
    +pagination(pagination)
  form(
    method = "POST"
    action = ``
    id = "form-delete-song"
    data-path = `${prefixAdmin}/songs/delete`
    )
  form(
      action = ``
      method = "POST"
      data-path = `${prefixAdmin}/songs/change-status`
      id = `form-change-status`
    )
  script(src = "/admin/js/song.js")