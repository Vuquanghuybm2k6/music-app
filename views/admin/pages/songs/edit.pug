extends ../../layouts/default.pug

block main
  h1(class="mb-4") #{pageTitle}

  form(
    action=`${prefixAdmin}/songs/edit/${song.id}?_method=PATCH`
    method="POST"
    enctype="multipart/form-data"
  )
    div(class="form-group")
      label(for="title") Tiêu đề
      input(
        type="text"
        class="form-control"
        id="title"
        name="title"
        required
        value=song.title
      )

    div(class="form-group")
      label(for="topic") Chủ đề
      select(
        name="topicId"
        id="topic"
        class="form-control"
        required
      )
        option(value="" disabled) -- Chọn chủ đề --
        each item in topics
          option(
            value=item.id
            selected=(item.id == song.topicId)
          ) #{item.title}

    div(class="form-group")
      label(for="singer") Ca sĩ
      select(
        name="singerId"
        id="singer"
        class="form-control"
        required
      )
        option(value="" disabled) -- Chọn ca sĩ --
        each item in singers
          option(
            value=item.id
            selected=(item.id == song.singerId)
          ) #{item.fullName}

    div(class="form-group" upload-image)
      label(for="thumbnail") Ảnh
      input(
        type="file"
        class="form-control-file"
        id="avatar"
        name="avatar"
        accept="image/*"
        upload-image-input
      )
      img(
        src=song.avatar
        upload-image-preview
      )

    div(class="form-group" upload-audio)
      label(for="audio") File âm thanh
      input(
        type="file"
        class="form-control-file"
        id="audio"
        name="audio"
        accept="audio/*"
        upload-audio-input
      )
      audio(controls upload-audio-play)
        source(src = song.audio)

    div(class="form-group")
      label(for="lyrics") Lời bài hát
      textarea(
        id="lyrics"
        name="lyrics"
        class="form-control"
        rows="20"
      ) #{song.lyrics}
    div(class="form-group")
      label(for="desc") Mô tả
      textarea(
        id="desc"
        name="description"
        class="form-control textarea-mce"
        rows="5"
      ) #{song.description}

      div(class="form-group form-check form-check-inline")
        input(
          type="radio"
          class="form-check-input"
          id="statusActive"
          name="status"
          value="active"
          checked=(song.status == "active" ? true : false)
        )
        label(for="statusActive" class="form-check-label") Hoạt động

      div(class="form-group form-check form-check-inline")
        input(
          type="radio"
          class="form-check-input"
          id="statusInActive"
          name="status"
          value="inactive"
          checked=(song.status == "inactive" ? true : false)
        )
        label(for="statusInActive" class="form-check-label") Dừng

    button(type="submit" class="btn btn-primary") Cập nhật