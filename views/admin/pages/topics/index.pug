extends ../../layouts/default.pug
include ../../mixins/form-change-multi.pug

block main 
  h2(class ="mb-4") #{pageTitle}

  .card.mb-3 
    .card-header Danh sách 
    .card-body 
      .row 
        .col-8 
          +form-change-multi(`/${prefixAdmin}/topics/change-multi?_method=PATCH`)
        .col-4.text-right 
          a(
            href = `/${prefixAdmin}/topics/create`
            class = "btn btn-outline-success"
          ) + Thêm mới
        table(class = "table table-hover table-sm" checkbox-multi)
          thead
            tr 
              th 
                input(type = "checkbox" name = "checkall") 
              th STT
              th Hình ảnh 
              th Tiêu đề
              th Trạng thái
              th Hành động
          tbody 
            each item, index in topics
              tr 
                td 
                  input(type = "checkbox" name = "id" value = item.id)
                td #{index+1} 
                td 
                  img(src = item.avatar, alt = item.title width = "100px" height = "auto")
                td #{item.title}
                td
                  if (item.status =="active")
                    a(
                      href = `javascript: ;` 
                      class = "badge badge-success" 
                      data-status = item.status 
                      data-id = item.id 
                      button-change-status
                      ) Hoạt động
                  else 
                    a(
                      href = `javascript: ;` 
                      class = "badge badge-danger" 
                      data-status = item.status 
                      data-id = item.id 
                      button-change-status
                      ) Dừng hoạt động
                td 
                  a(class = "btn btn-secondary btn-sm mr-1" href =`/${prefixAdmin}/topics/detail/${item.id}`) Chi tiết
                  a(class = "btn btn-warning btn-sm mr-1" href =`/${prefixAdmin}/topics/edit/${item.id}`) Sửa
                  button(class = "btn btn-danger btn-sm" button-delete data-id = item.id) Xóa
  form(
    method = "POST"
    action = ``
    id = "form-delete-topic"
    data-path = `/${prefixAdmin}/topics/delete`
    )
  form(
      action = ``
      method = "POST"
      data-path = `/${prefixAdmin}/topics/change-status`
      id = `form-change-status`
    )
  script(src = "/admin/js/topic.js")